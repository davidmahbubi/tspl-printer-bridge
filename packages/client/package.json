{
  "name": "@davidmahbubi/tspl-bridge-sdk",
  "version": "0.1.0",
  "description": "Browser SDK for TSPL Print Bridge — print labels from web apps",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
