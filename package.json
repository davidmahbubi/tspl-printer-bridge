{
  "name": "node-tsp",
  "version": "0.1.0",
  "description": "TSPL label printing app for Bun",
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "bin": {
    "tspl-print": "src/cli.ts"
  },
  "dependencies": {
    "@node-tsp/core": "workspace:*"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "example": "bun run examples/shipping-label.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1"
  }
}
