{
  "name": "tspl-bridge-desktop",
  "version": "1.0.0",
  "description": "TSPL Print Bridge — local print server untuk printer label TSPL",
  "private": true,
  "author": "David Mahbubi",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "start": "bun run build && bun run scripts/fix-dev-appname.ts && electron .",
    "dist": "bun run build && electron-builder --mac",
    "dist:win": "bun run build && electron-builder --win"
  },
  "devDependencies": {
    "@davidmahbubi/tspl-bridge-core": "workspace:*",
    "@davidmahbubi/tspl-bridge-server": "workspace:*",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "id.davidmahbubi.tspl-bridge",
    "productName": "TSPL Print Bridge",
    "files": ["dist/**/*", "package.json"],
    "directories": { "output": "release" },
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "category": "public.app-category.utilities",
      "icon": "assets/icons/macos/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icons/windows/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
